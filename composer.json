{
	"name": "phpems/phpems",
	"version": "12.0.0",
	"require": {
		"php": ">=8.1",
		"ext-json": "*",
		"ext-pdo": "*",
		"ext-redis": "*",
		"ext-mbstring": "*",
		"ext-fileinfo": "*",
		"ext-gd": "*",
		"guzzlehttp/guzzle": "^7.10",
		"psr/log": "^3.0",
		"ext-openssl": "*",
		"ext-zip": "*",
		"endroid/qr-code": "^6.0",
		"ext-curl": "*",
		"yansongda/pay": "~3.7.0",
		"hyperf/pimple": "~2.2.0",
		"phpmailer/phpmailer": "^7.1",
        "ext-simplexml": "*",
		"paperdoc-dev/paperdoc-lib": "^0.8.3",
		"phpoffice/phpword": "^1.4",
      	"ext-dom": "*",
      	"ext-libxml": "*",
        "ext-ctype": "*"
    },
	"require-dev": {
		"phpunit/phpunit": "^9.5",
		"mockery/mockery": "^1.5",
		"phpstan/phpstan": "^1.10"
	},
	"autoload": {
		"psr-4": {
			"PHPEMS\\App\\": "app/",
			"PHPEMS\\Lib\\": "lib/",
			"PHPEMS\\Plugins\\": "plugins/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"PHPEMS\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"test:coverage": "phpunit --coverage-html coverage",
		"test:unit": "phpunit --testsuite Unit",
		"test:integration": "phpunit --testsuite Integration",
		"analyze": "phpstan analyse lib app --level=5"
	},
	"config": {
		"allow-plugins": {
			"codewithkyrian/platform-package-installer": true
		}
	}
}
